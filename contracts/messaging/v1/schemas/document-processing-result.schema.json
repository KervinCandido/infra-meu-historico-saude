{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:meu-historico-saude:messaging:v1:document-processing-result",
  "title": "Document Processing Result",
  "description": "Comunica o resultado terminal agregado do processamento de um documento.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventType",
    "eventId",
    "correlationId",
    "occurredAt",
    "documentId",
    "patientId"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "eventType": {
      "type": "string",
      "enum": [
        "DOCUMENT_PROCESSING_COMPLETED",
        "DOCUMENT_PROCESSING_FAILED"
      ]
    },
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Identificador único e estável desta resposta terminal."
    },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "eventId da solicitação que originou a resposta."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "documentId": {
      "type": "string",
      "format": "uuid"
    },
    "patientId": {
      "type": "string",
      "format": "uuid"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "primaryDocumentType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "specialty": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 100
    },
    "documentDate": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "confidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/processedResult"
      }
    },
    "error": {
      "$ref": "#/definitions/processingError"
    }
  },
  "oneOf": [
    {
      "properties": {
        "eventType": {
          "const": "DOCUMENT_PROCESSING_COMPLETED"
        }
      },
      "required": [
        "summary",
        "primaryDocumentType",
        "specialty",
        "documentDate",
        "confidence",
        "results"
      ],
      "not": {
        "required": [
          "error"
        ]
      }
    },
    {
      "properties": {
        "eventType": {
          "const": "DOCUMENT_PROCESSING_FAILED"
        }
      },
      "required": [
        "error"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "summary"
            ]
          },
          {
            "required": [
              "primaryDocumentType"
            ]
          },
          {
            "required": [
              "specialty"
            ]
          },
          {
            "required": [
              "documentDate"
            ]
          },
          {
            "required": [
              "confidence"
            ]
          },
          {
            "required": [
              "results"
            ]
          }
        ]
      }
    }
  ],
  "definitions": {
    "processedResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resultId",
        "documentType",
        "documentDate",
        "data"
      ],
      "properties": {
        "resultId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "documentType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "documentDate": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "processingError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retryable"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "retryable": {
          "type": "boolean"
        }
      }
    }
  }
}