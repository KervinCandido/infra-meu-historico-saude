{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:meu-historico-saude:messaging:v1:document-processed-response",
  "title": "Document Processed Response",
  "description": "Comunica o resultado do processamento de um documento de saúde.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventType",
    "eventId",
    "occurredAt",
    "documentId",
    "patientId",
    "status",
    "document",
    "error"
  ],
  "properties": {
    "schemaVersion": {
      "description": "Versão do contrato da mensagem.",
      "type": "integer",
      "const": 1
    },
    "eventType": {
      "description": "Tipo lógico do evento.",
      "type": "string",
      "const": "DOCUMENT_PROCESSED_RESPONSE"
    },
    "eventId": {
      "description": "Identificador da solicitação original que originou a resposta.",
      "type": "string",
      "format": "uuid"
    },
    "occurredAt": {
      "description": "Momento em que a resposta foi produzida, em UTC.",
      "type": "string",
      "format": "date-time"
    },
    "documentId": {
      "description": "Identificador do documento original.",
      "type": "string",
      "format": "uuid"
    },
    "patientId": {
      "description": "Identificador do paciente proprietário do documento.",
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "description": "Resultado terminal do processamento.",
      "type": "string",
      "enum": [
        "PROCESSED",
        "FAILED"
      ]
    },
    "document": {
      "description": "Resultado estruturado extraído do documento.",
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "error": {
      "description": "Erro estruturado quando o processamento falha.",
      "oneOf": [
        {
          "$ref": "#/definitions/processingError"
        },
        {
          "type": "null"
        }
      ]
    },
    "errorDetail": {
      "description": "Campo legado mantido temporariamente durante a migração.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 2000
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "PROCESSED"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "document": {
            "type": "object"
          },
          "error": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "FAILED"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "document": {
            "type": "null"
          },
          "error": {
            "$ref": "#/definitions/processingError"
          }
        }
      }
    }
  ],
  "definitions": {
    "processingError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retryable"
      ],
      "properties": {
        "code": {
          "description": "Código estável e apropriado para tratamento automatizado.",
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "message": {
          "description": "Descrição segura e legível do erro.",
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "retryable": {
          "description": "Indica se uma nova tentativa pode resolver a falha.",
          "type": "boolean"
        }
      }
    }
  }
}

