{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:meu-historico-saude:messaging:v1:document-processing-requested",
  "title": "Document Processing Requested",
  "description": "Solicita o processamento assíncrono de um documento de saúde.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventType",
    "eventId",
    "occurredAt",
    "documentId",
    "patientId",
    "fileUrl",
    "contentType"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "eventType": {
      "type": "string",
      "const": "DOCUMENT_PROCESSING_REQUESTED"
    },
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Identificador único da solicitação."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$",
      "description": "Data e hora UTC em que a solicitação foi criada."
    },
    "documentId": {
      "type": "string",
      "format": "uuid"
    },
    "patientId": {
      "type": "string",
      "format": "uuid"
    },
    "fileUrl": {
      "type": "string",
      "format": "uri",
      "minLength": 1,
      "description": "URL interna, sem credenciais, para leitura do arquivo."
    },
    "contentType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    }
  }
}