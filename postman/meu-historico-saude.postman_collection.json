{
  "info": {
    "_postman_id": "64629216-9f9f-4cf1-853d-c23a1e8fc609",
    "name": "Meu Histórico Saúde - Patient Document Service",
    "description": "Collection para testes locais e via Kong do Patient Document Service.\n\nFluxo recomendado:\n1. Selecione o environment fornecido.\n2. Preencha devClientSecret e, para os testes técnicos, aiClientSecret.\n3. Execute 'Obter token - cliente de desenvolvimento'.\n4. Execute 'Cadastrar paciente'; o patientId será salvo automaticamente.\n5. Em 'Enviar documento', selecione manualmente um arquivo; o documentId será salvo.\n6. Para testar pelo Kong, altere somente a variável baseUrl para a URL/rota exposta pelo gateway.\n\nOs secrets e tokens não são incluídos no arquivo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "keycloakBaseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "realm",
      "value": "meu-historico-saude",
      "type": "string"
    },
    {
      "key": "devClientId",
      "value": "patient-document-dev-client",
      "type": "string"
    },
    {
      "key": "devClientSecret",
      "value": "",
      "type": "string"
    },
    {
      "key": "aiClientId",
      "value": "ai-processing-service",
      "type": "string"
    },
    {
      "key": "aiClientSecret",
      "value": "",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "aiAccessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "patientId",
      "value": "",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "00 - Autenticação",
      "description": "Obtém tokens pelo fluxo OAuth 2.0 client_credentials do Keycloak.",
      "item": [
        {
          "name": "Obter token - cliente de desenvolvimento",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{devClientId}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{devClientSecret}}",
                  "type": "text"
                }
              ]
            },
            "url": "{{keycloakBaseUrl}}/realms/{{realm}}/protocol/openid-connect/token",
            "description": "Obtém um token técnico com os escopos de desenvolvimento da API. O access_token é salvo automaticamente em accessToken."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test(\"Access token retornado\", function () { pm.expect(body.access_token).to.be.a(\"string\").and.not.empty; });",
                  "pm.environment.set(\"accessToken\", body.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Obter token - serviço de IA",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{aiClientId}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{aiClientSecret}}",
                  "type": "text"
                }
              ]
            },
            "url": "{{keycloakBaseUrl}}/realms/{{realm}}/protocol/openid-connect/token",
            "description": "Obtém o token técnico do processador de IA. Esse cliente deve possuir somente documents:file:read. O token é salvo em aiAccessToken."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test(\"Access token da IA retornado\", function () { pm.expect(body.access_token).to.be.a(\"string\").and.not.empty; });",
                  "pm.environment.set(\"aiAccessToken\", body.access_token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Documentação pública",
      "item": [
        {
          "name": "OpenAPI JSON",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v3/api-docs",
            "description": "A especificação OpenAPI deve permanecer pública, inclusive quando acessada pelo Kong."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Resposta JSON\", function () { pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Swagger UI",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/swagger-ui.html",
            "description": "Entrada pública do Swagger UI."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200 ou redirecionamento\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 301, 302, 307, 308]); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Pacientes",
      "item": [
        {
          "name": "Cadastrar paciente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Paciente Postman {{$timestamp}}\",\n  \"birthDate\": \"1990-01-15\",\n  \"email\": \"postman.{{$timestamp}}@example.com\",\n  \"phone\": \"21999999999\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/patients",
            "description": "Requer patients:write. O identificador retornado é salvo automaticamente em patientId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 201\", function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.test(\"Paciente possui ID\", function () { pm.expect(body.id).to.be.a(\"string\").and.not.empty; });",
                  "pm.environment.set(\"patientId\", body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar pacientes",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/patients",
            "description": "Requer patients:read."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Resposta é uma lista\", function () { pm.expect(pm.response.json()).to.be.an(\"array\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Consultar paciente por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/patients/{{patientId}}",
            "description": "Requer patients:read."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"ID corresponde ao ambiente\", function () { pm.expect(pm.response.json().id).to.eql(pm.environment.get(\"patientId\")); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Documentos do paciente",
      "item": [
        {
          "name": "Enviar documento",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Selecione manualmente um arquivo de teste no Postman."
                }
              ]
            },
            "url": "{{baseUrl}}/patients/{{patientId}}/documents",
            "description": "Requer documents:write. Selecione um arquivo antes de enviar. O ID retornado é salvo automaticamente em documentId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 201\", function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.test(\"Documento possui ID\", function () { pm.expect(body.id).to.be.a(\"string\").and.not.empty; });",
                  "pm.environment.set(\"documentId\", body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar documentos paginados",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}/documents?page=0&size=10",
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "documentType",
                  "value": "EXAME_LABORATORIAL",
                  "disabled": true
                },
                {
                  "key": "specialty",
                  "value": "ENDOCRINOLOGIA",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "PROCESSED",
                  "disabled": true
                },
                {
                  "key": "keyword",
                  "value": "glicemia",
                  "disabled": true
                },
                {
                  "key": "startDate",
                  "value": "2026-01-01",
                  "disabled": true
                },
                {
                  "key": "endDate",
                  "value": "2026-12-31",
                  "disabled": true
                }
              ]
            },
            "description": "Requer documents:read. Os filtros opcionais já estão cadastrados e desabilitados."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test(\"Resposta paginada\", function () { pm.expect(body).to.have.keys(\"content\", \"page\", \"size\", \"totalElements\", \"totalPages\", \"first\", \"last\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Consultar timeline",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/patients/{{patientId}}/timeline",
            "description": "Requer documents:read."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Resposta é uma lista\", function () { pm.expect(pm.response.json()).to.be.an(\"array\"); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 - Documentos individuais",
      "item": [
        {
          "name": "Consultar documento por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/documents/{{documentId}}",
            "description": "Requer documents:read."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"ID corresponde ao ambiente\", function () { pm.expect(pm.response.json().id).to.eql(pm.environment.get(\"documentId\")); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar resultados processados",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/documents/{{documentId}}/processed-results",
            "description": "Requer documents:read. Um arquivo pode gerar múltiplos resultados clínicos."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Resposta é uma lista\", function () { pm.expect(pm.response.json()).to.be.an(\"array\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Baixar arquivo original - cliente de desenvolvimento",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/documents/{{documentId}}/file",
            "description": "Requer documents:file:read. Use Send and Download para salvar o arquivo."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Content-Disposition presente\", function () { pm.expect(pm.response.headers.get(\"Content-Disposition\")).to.exist; });"
                ]
              }
            }
          ]
        },
        {
          "name": "Atualizar resultado da IA manualmente",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentType\": \"EXAME_LABORATORIAL\",\n  \"specialty\": \"ENDOCRINOLOGIA\",\n  \"documentDate\": \"2026-06-10\",\n  \"summary\": \"Exame laboratorial contendo informações de glicemia e colesterol.\",\n  \"keywords\": [\n    \"glicemia\",\n    \"colesterol\",\n    \"exame laboratorial\"\n  ],\n  \"confidence\": 0.92,\n  \"status\": \"PROCESSED\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/documents/{{documentId}}/ai-result",
            "description": "Requer documents:ai-result:write."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Status processado\", function () { pm.expect(pm.response.json().status).to.eql(\"PROCESSED\"); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05 - Matriz de autorização",
      "description": "Testes úteis para conferir a aplicação das políticas diretamente e pelo Kong.",
      "item": [
        {
          "name": "Sem token - listar pacientes deve retornar 401",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/patients"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 401\", function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Token da IA - listar pacientes deve retornar 403",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{aiAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/patients",
            "description": "O cliente ai-processing-service não possui patients:read."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 403\", function () { pm.response.to.have.status(403); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Token da IA - baixar arquivo deve retornar 200",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{aiAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/documents/{{documentId}}/file",
            "description": "O cliente ai-processing-service possui documents:file:read."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
